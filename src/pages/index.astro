---
import Layout from '../layouts/Layout.astro';
import DotsCanvas from '../components/dots-canvas.astro';
import text from '../../text.md?raw';

const normalizedText = text
  .split(/\n/)
  .map((line) => line.trim())
  .join(' ')
  .replace(/\s+/g, ' ')
  .trim();

const SYMBOL_POOL = '!@#$%^&*()_+-=[]{}|;\':",.<>?/~`\\°•·…¿¡¥€£©®™';
const pick = (str: string) => str[Math.floor(Math.random() * str.length)];

const placeholderSymbols = normalizedText.split('').map(() => pick(SYMBOL_POOL));

const words = normalizedText.split(/\s+/);
type Segment = { type: 'word'; chars: string[]; startIndex: number } | { type: 'space'; startIndex: number };
const segments: Segment[] = [];
let idx = 0;
for (let w = 0; w < words.length; w++) {
  const wordChars = words[w].split('');
  segments.push({ type: 'word', chars: wordChars, startIndex: idx });
  idx += wordChars.length;
  if (w < words.length - 1) {
    segments.push({ type: 'space', startIndex: idx });
    idx += 1;
  }
}
---

<Layout>
  <DotsCanvas />

  <main class="terminal-wrap">
    <div class="terminal">
      <div class="terminal-header">
        <span class="terminal-dot red"></span>
        <span class="terminal-dot yellow"></span>
        <span class="terminal-dot green"></span>
        <span class="terminal-title">congratulation.txt</span>
      </div>
      <div class="terminal-body">
        <div class="terminal-prompt">$ cat congratulation.txt</div>
        <div id="decode-output" class="terminal-output terminal-output-chars">
          {segments.map((seg) =>
            seg.type === 'word' ? (
              <span class="word">
                {seg.chars.map((_, i) => (
                  <span class="char">{placeholderSymbols[seg.startIndex + i]}</span>
                ))}
              </span>
            ) : (
              <span class="char">{placeholderSymbols[seg.startIndex]}</span>
            )
          )}
        </div>
        <div class="terminal-prompt terminal-input-line">
          $ <input
            type="text"
            id="decode-cmd"
            class="terminal-input"
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
            placeholder=""
            maxlength="30"
          /><span class="cursor" id="input-cursor">|</span>
        </div>
        <div id="decode-error" class="terminal-error" aria-live="polite"></div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ normalizedText }}>
  const SYMBOL_POOL = '!@#$%^&*()_+-=[]{}|;\':",.<>?/~`\\°•·…¿¡¥€£©®™';
  const outputEl = document.getElementById('decode-output');
  const inputEl = document.getElementById('decode-cmd');
  const cursorEl = document.getElementById('input-cursor');
  const errorEl = document.getElementById('decode-error');

  const TRIGGER_COMMANDS = ['decrypt', 'decode', 'love', 'open'];
  const BLOCK_DURATION_MS = 40;
  const CYCLES_BEFORE_REVEAL = 2;
  const CYCLE_MS = 25;
  const LIVE_CIPHER_STEP_MS = 95;
  const LIVE_CIPHER_FLIP_DURATION_MS = 140;
  const CHARS_PER_LINE = 28;

  function pick() {
    return SYMBOL_POOL[Math.floor(Math.random() * SYMBOL_POOL.length)];
  }

  const spans = outputEl.querySelectorAll('.char');
  const len = spans.length;

  function updateCipherBatch() {
    const numLines = Math.ceil(len / CHARS_PER_LINE);
    for (let line = 0; line < numLines; line++) {
      const lineStart = line * CHARS_PER_LINE;
      const lineEnd = Math.min(lineStart + CHARS_PER_LINE, len);
      const lineLen = lineEnd - lineStart;
      if (lineLen === 0) continue;
      const idx = lineStart + Math.floor(Math.random() * lineLen);
      const span = spans[idx];
      if (!span.classList.contains('decoded')) {
        span.classList.add('cipher-flip');
        setTimeout(() => {
          span.textContent = pick();
          span.classList.remove('cipher-flip');
        }, LIVE_CIPHER_FLIP_DURATION_MS);
      }
    }
  }

  updateCipherBatch();
  const liveCipherTimer = setInterval(updateCipherBatch, LIVE_CIPHER_STEP_MS);

  function setInputWidth() {
    const len = Math.max(1, inputEl.value.length);
    inputEl.style.width = `${len}ch`;
  }
  setInputWidth();
  inputEl.addEventListener('input', setInputWidth);

  function runDecodeAnimation() {
    clearInterval(liveCipherTimer);
    const target = normalizedText;
    const spanList = outputEl.querySelectorAll('.char');
    const len = target.length;

    function step(i) {
      if (i >= len) {
        cursorEl.style.visibility = 'hidden';
        return;
      }
      const span = spanList[i];
      span.classList.add('current');
      let cycle = 0;
      function tick() {
        if (cycle < CYCLES_BEFORE_REVEAL) {
          span.textContent = pick();
          cycle++;
          setTimeout(tick, CYCLE_MS);
        } else {
          span.textContent = target[i];
          span.classList.remove('current');
          span.classList.add('decoded');
          setTimeout(step, BLOCK_DURATION_MS, i + 1);
        }
      }
      setTimeout(tick, CYCLE_MS);
    }
    step(0);
  }

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.add('visible');
  }

  function clearError() {
    errorEl.textContent = '';
    errorEl.classList.remove('visible');
  }

  inputEl.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    e.preventDefault();
    const cmd = inputEl.value.trim().toLowerCase();
    clearError();
    if (TRIGGER_COMMANDS.includes(cmd)) {
      inputEl.disabled = true;
      inputEl.style.opacity = '0.5';
      cursorEl.style.animation = 'none';
      runDecodeAnimation();
    } else if (cmd === '') {
      showError('Введи команду :)');
    } else if (cmd === 'help' || cmd === '?') {
      showError('Попробуй: decrypt, decode или love');
    } else {
      showError(`command not found: ${cmd}`);
    }
  });

  inputEl.addEventListener('input', () => clearError());
  inputEl.focus({ preventScroll: true });
</script>

<style>
  .terminal-wrap {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    box-sizing: border-box;
  }

  .terminal {
    width: 100%;
    max-width: 28rem;
    background: rgba(0, 10, 0, 0.92);
    border: 1px solid rgba(0, 255, 100, 0.35);
    border-radius: 12px;
    box-shadow:
      0 0 0 1px rgba(0, 255, 100, 0.1),
      0 25px 50px -12px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(0, 255, 100, 0.06);
    font-family: var(--font-mono), ui-monospace, monospace;
    overflow: hidden;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    background: rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid rgba(0, 255, 100, 0.2);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot.red {
    background: #ff5f56;
  }

  .terminal-dot.yellow {
    background: #ffbd2e;
  }

  .terminal-dot.green {
    background: #27c93f;
  }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.75rem;
    color: rgba(0, 255, 100, 0.6);
    letter-spacing: 0.02em;
  }

  .terminal-body {
    padding: 1rem 1.25rem 1.5rem;
    max-height: calc(100vh - 8rem);
    max-height: calc(100dvh - 8rem);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .terminal-body::-webkit-scrollbar {
    display: none;
  }

  .terminal-prompt {
    color: #00ff64;
    font-size: 0.8125rem;
    margin-bottom: 0.5rem;
    opacity: 0.95;
  }

  .terminal-output {
    color: rgba(0, 255, 120, 0.92);
    font-size: 0.8125rem;
    line-height: 1.7;
    white-space: normal;
    word-wrap: break-word;
    margin: 0 0 1rem 0;
    font-weight: 400;
  }

  .terminal-output-chars {
    display: block;
    word-break: break-word;
  }

  .terminal-output-chars .word {
    white-space: nowrap;
    display: inline;
  }

  .terminal-output-chars .char {
    display: inline-block;
    width: 1ch;
    min-width: 1ch;
    text-align: center;
    vertical-align: top;
    box-sizing: border-box;
    transition: opacity 0.14s ease;
  }

  .terminal-output-chars .char.cipher-flip {
    opacity: 0.25;
  }

  .terminal-output-chars .char.current {
    background: rgba(0, 255, 100, 0.35);
    box-shadow: 0 0 0 1px rgba(0, 255, 100, 0.5);
    border-radius: 1px;
  }

  .cursor {
    animation: blink 1s step-end infinite;
    color: #00ff64;
  }

  .terminal-input-line {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 0;
  }

  .terminal-input {
    flex: 0 0 auto;
    width: 1ch;
    min-width: 1ch;
    max-width: 30ch;
    background: transparent;
    border: none;
    outline: none;
    color: #00ff64;
    font: inherit;
    font-size: 0.8125rem;
    padding: 0;
    margin: 0;
    caret-color: transparent;
  }

  .terminal-input::placeholder {
    color: rgba(0, 255, 100, 0.3);
  }

  .terminal-error {
    color: #ff6b6b;
    font-size: 0.8125rem;
    margin-top: 0.5rem;
    min-height: 1.25em;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .terminal-error.visible {
    opacity: 1;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 380px) {
    .terminal-body {
      padding: 0.875rem 1rem 1.25rem;
    }

    .terminal-output,
    .terminal-input {
      font-size: 0.75rem;
    }
  }
</style>
