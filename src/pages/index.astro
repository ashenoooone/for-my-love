---
import Layout from '../layouts/Layout.astro'
import DotsCanvas from '../components/dots-canvas.astro'
import Terminal from '../components/Terminal.astro'
import DecodeOutput from '../components/DecodeOutput.astro'
import TerminalInput from '../components/TerminalInput.astro'
import CommandList from '../components/CommandList.astro'
import text from '../../text.md?raw'

const normalizedText = text
  .split(/\n/)
  .map((line) => line.trim())
  .join(' ')
  .replace(/\s+/g, ' ')
  .trim()

const SYMBOL_POOL = '!@#$%^&*()_+-=[]{}|;\':",.<>?/~`\\°•·…¿¡¥€£©®™'
const pick = (str: string) => str[Math.floor(Math.random() * str.length)]

const placeholderSymbols = normalizedText.split('').map(() => pick(SYMBOL_POOL))

const words = normalizedText.split(/\s+/)
type Segment = { type: 'word'; chars: string[]; startIndex: number } | { type: 'space'; startIndex: number }
const segments: Segment[] = []
let idx = 0
for (let w = 0; w < words.length; w++) {
  const wordChars = words[w].split('')
  segments.push({ type: 'word', chars: wordChars, startIndex: idx })
  idx += wordChars.length
  if (w < words.length - 1) {
    segments.push({ type: 'space', startIndex: idx })
    idx += 1
  }
}
---

<Layout>
  <DotsCanvas />

  <main class="terminal-wrap">
    <div class="terminal-layout">
      <Terminal title="congratulation.txt">
        <div class="terminal-prompt">$ cat congratulation.txt</div>
        <DecodeOutput segments={segments} placeholderSymbols={placeholderSymbols} />
        <TerminalInput />
      </Terminal>
      <CommandList />
    </div>
  </main>
</Layout>

<script define:vars={{ normalizedText }}>
  const SYMBOL_POOL = '!@#$%^&*()_+-=[]{}|;\':",.<>?/~`\\°•·…¿¡¥€£©®™'
  const outputEl = document.getElementById('decode-output')
  const inputEl = document.getElementById('decode-cmd')
  const cursorEl = document.getElementById('input-cursor')
  const errorEl = document.getElementById('decode-error')
  const successEl = document.getElementById('decode-success')

  const TRIGGER_COMMANDS = ['🐿', 'белка']
  const BLOCK_DURATION_MS = 6
  const CYCLES_BEFORE_REVEAL = 0
  const CYCLE_MS = 12
  const LIVE_CIPHER_FLIP_DURATION_MS = 140
  const CHARS_PER_LINE = 28

  function pick() {
    return SYMBOL_POOL[Math.floor(Math.random() * SYMBOL_POOL.length)]
  }

  const spans = outputEl.querySelectorAll('.char')
  const len = spans.length

  function updateCipherBatch() {
    const numLines = Math.ceil(len / CHARS_PER_LINE)
    for (let line = 0; line < numLines; line++) {
      const lineStart = line * CHARS_PER_LINE
      const lineEnd = Math.min(lineStart + CHARS_PER_LINE, len)
      const lineLen = lineEnd - lineStart
      if (lineLen === 0) continue
      const idx = lineStart + Math.floor(Math.random() * lineLen)
      const span = spans[idx]
      if (!span.classList.contains('decoded')) {
        span.classList.add('cipher-flip')
        setTimeout(() => {
          if (!span.classList.contains('decoded')) {
            span.textContent = pick()
          }
          span.classList.remove('cipher-flip')
        }, LIVE_CIPHER_FLIP_DURATION_MS)
      }
    }
  }

  updateCipherBatch()
  setInterval(updateCipherBatch, 95)

  function setInputWidth() {
    const len = Math.max(1, inputEl.value.length)
    inputEl.style.width = `${len}ch`
  }
  setInputWidth()
  inputEl.addEventListener('input', setInputWidth)

  function runDecodeAnimation() {
    const target = normalizedText
    const spanList = outputEl.querySelectorAll('.char')
    const len = target.length

    function step(i) {
      if (i >= len) {
        cursorEl.style.visibility = 'hidden'
        return
      }
      const span = spanList[i]
      span.classList.add('current')
      let cycle = 0
      function tick() {
        if (cycle < CYCLES_BEFORE_REVEAL) {
          span.textContent = pick()
          cycle++
          setTimeout(tick, CYCLE_MS)
        } else {
          span.textContent = target[i]
          span.classList.remove('current')
          span.classList.add('decoded')
          setTimeout(step, BLOCK_DURATION_MS, i + 1)
        }
      }
      setTimeout(tick, CYCLES_BEFORE_REVEAL > 0 ? CYCLE_MS : 0)
    }
    step(0)
  }

  function showError(msg) {
    errorEl.textContent = msg
    errorEl.classList.add('visible')
  }

  function clearError() {
    errorEl.textContent = ''
    errorEl.classList.remove('visible')
  }

  function showSuccess(msg) {
    if (successEl) {
      successEl.textContent = msg
      successEl.classList.add('visible')
    }
  }

  const HINT_RIDDLE = 'Пароль - наш с тобой любимый стикер и гифка.'
  const HINT_NUDGE = 'Подсказка: введи одно эмодзи или слово'

  let wrongAttempts = 0

  inputEl.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return
    e.preventDefault()
    const cmd = inputEl.value.trim().toLowerCase()
    clearError()
    if (TRIGGER_COMMANDS.includes(cmd)) {
      inputEl.disabled = true
      inputEl.style.opacity = '0.5'
      cursorEl.style.animation = 'none'
      showSuccess('✓ Верно! Расшифровываю...')
      setTimeout(runDecodeAnimation, 700)
    } else if (cmd === '') {
      showError('Введи команду :)')
    } else if (cmd === 'help' || cmd === '?' || cmd === 'hint' || cmd === 'подсказка') {
      showError(cmd === 'hint' || cmd === 'подсказка' ? HINT_NUDGE : HINT_RIDDLE)
    } else {
      wrongAttempts += 1
      if (wrongAttempts >= 2) {
        showError(`command not found: ${cmd}. Введи help для подсказки.`)
      } else {
        showError(`command not found: ${cmd}`)
      }
    }
  })

  inputEl.addEventListener('input', () => clearError())

  const inputLineWrap = document.getElementById('input-line-wrap')
  if (inputLineWrap) {
    inputLineWrap.addEventListener('click', (e) => {
      if (e.target !== inputEl) {
        e.preventDefault()
        inputEl.focus()
      }
    })
    inputLineWrap.addEventListener('keydown', (e) => {
      if (e.target === inputEl) return
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        inputEl.focus()
      }
    })
  }

  inputEl.focus({ preventScroll: true })
</script>

<style>
  .terminal-wrap {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    padding-left: max(1rem, env(safe-area-inset-left));
    padding-right: max(1rem, env(safe-area-inset-right));
    box-sizing: border-box;
    overflow-x: hidden;
    width: 100%;
  }

  .terminal-layout {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 50rem;
    min-width: 0;
  }

  .terminal-layout .terminal-prompt {
    color: #00ff64;
    font-size: 0.8125rem;
    margin-bottom: 0.5rem;
    opacity: 0.95;
  }

  @media (max-width: 640px) {
    .terminal-layout {
      flex-direction: column;
      align-items: stretch;
    }

    .terminal-wrap {
      padding-left: max(0.75rem, env(safe-area-inset-left));
      padding-right: max(0.75rem, env(safe-area-inset-right));
    }
  }
</style>
