---
const commands = [
  { cmd: 'help / ?', desc: 'Подсказка к ключу' },
  { cmd: 'hint / подсказка', desc: 'Вторая подсказка' },
]
---

<aside class="command-list" aria-label="Доступные команды">
  <h2 class="command-list-title">команды</h2>
  <ul class="command-list-items">
    {
      commands.map(({ cmd, desc }) => (
        <li class="command-list-item">
          <code class="command-list-cmd">{cmd}</code>
          <span class="command-list-desc">{desc}</span>
        </li>
      ))
    }
  </ul>
</aside>

<style>
  .command-list {
    width: 100%;
    max-width: 18rem;
    background: rgba(0, 10, 0, 0.88);
    border: 1px solid rgba(0, 255, 100, 0.28);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    font-family: var(--font-mono), ui-monospace, monospace;
    box-shadow: 0 0 0 1px rgba(0, 255, 100, 0.08);
  }

  .command-list-title {
    margin: 0 0 0.75rem 0;
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(0, 255, 100, 0.5);
    text-transform: lowercase;
    letter-spacing: 0.06em;
  }

  .command-list-items {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .command-list-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(0, 255, 100, 0.08);
  }

  .command-list-item:last-child {
    border-bottom: none;
  }

  .command-list-cmd {
    font-size: 0.8rem;
    color: #00ff64;
    background: rgba(0, 255, 100, 0.08);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    display: inline-block;
    width: fit-content;
  }

  .command-list-desc {
    font-size: 0.7rem;
    color: rgba(0, 255, 120, 0.7);
  }

  @media (max-width: 640px) {
    .command-list {
      max-width: 100%;
    }
  }
</style>
